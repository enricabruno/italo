    rdam:P30156 "Il castello dei destini incrociati" ;
    rdam:P30088 "Milano" ;
    rdam:P30011 "1973"^^xsd:integer ;
    rdam:P30420 "Mondadori" ;
    rdam:P30033 :introduzione,
                :capitoloUno,
                :capitoloDue,
                :capitoloTre,
                :capitoloQuattro,
                :capitoloCinque,
                :capitoloSei,
                :tuttelealtrestorie .

# ----- Tabella 6: lrmoo:F3_Manifestation -----

