    rdaw:P10436 "Italo Calvino" .


# ----- Tabella 2: lrmoo:F28_Expression_Creation -----

:e-creat-castello a lrmoo:F28_Expression_Creation ;
    lrmoo:R17_created :il-castello-dei-destini-incrociati-e ;
    crm:P33_used_specific_technique :lipophony_cons,
                                    :mazzo-il-castello-dei-destini-incrociati, 
                                    :magic-square_cons .


