# ----- Tabella 10: vir:IC9_Representation -----

:re-di-spade-storiaCinque-orlando a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :orlando-guerriero ;
    crm:P190_has_symbolic_content "Orlando paladino che mulinava la sua Durlindana." .

:dieci-di-spade-storiaCinque-battaglia a vir:IC9_Representation ;
    rdf:type gc:G5_Narrative_Event ;
    crm:K14_symbolize :battaglia-destino_bellicoso ;
    crm:P190_has_symbolic_content "E subito i nostri occhi furono come accecati dal polverone delle battaglie [...]." .

:regina-di-spade-storiaCinque-angelica a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :angelica-amata ;
    crm:P190_has_symbolic_content "donna bionda, che in mezzo alle lame affilate e alle piastre di ferro affaccia l'inafferrabile sorriso d'un gioco sensuale, noi riconoscemmo Angelica, la maga venuta dal Catai per la rovina delle armate franche [...]." .

:dieci-di-bastoni-storiaCinque-bosco a vir:IC9_Representation ;
    rdf:type gc:G13_Narrative_Location ;
    crm:K14_symbolize :bosco-amore ;
    crm:P190_has_symbolic_content "Vedemmo la foresta schiudersi malvolentieri all'avanzare del campione [...] Il bosco dell'amore, Orlando, non é luogo per te!" .

:il-carro-storiaCinque-angelica_incede a vir:IC9_Representation ;
    rdf:type gc:G5_Narrative_Event ;
    crm:K14_symbolize :angelica_incede-oggetto_di_amore_inseguito ;
    crm:P190_has_symbolic_content "una sola visione lo occupava: [...] l'incedere fatato d'Angelica nel bosco [...]." .

:lo-amore-storiaCinque-amore_angelica_e_medoro a vir:IC9_Representation ;
    rdf:type gc:G5_Narrative_Event ;
    crm:K14_symbolize :amore_angelica_e_medoro-amore_non_corrisposto ;
    crm:P190_has_symbolic_content "una stretta d'amore morbida e struggente univa intanto Angelica e Medoro." .

:fante-di-bastoni-storiaCinque-medoro a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :medoro-amante ;
    crm:P190_has_symbolic_content "un giovanottino del seguito, snello e civettuolo come una fanciulla" .

:il-sole-storiaCinque-amorino_volante a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :amorino_volante-intelletto_fuggente_di_orlando ;
    crm:P190_has_symbolic_content "Un amorino fuggiva a volo portando via il lume della saggezza d'Orlando [...]." .

:la-forza-storiaCinque-orlando_feroce a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :orlando_feroce-violenza ;
    crm:P190_has_symbolic_content "quel fiore della cavalleria trasformato in una cieca esplosione tellurica [...]." .

:cinque-di-bastoni-storiaCinque-schianto_dei_tronchi a vir:IC9_Representation ;
    rdf:type gc:G5_Narrative_Event ;
    crm:K14_symbolize :schianto_dei_tronchi_violenza ;
    crm:P190_has_symbolic_content "schianto dei tronchi di quercia sradicati dall'ossesso" .

:sette-di-spade-storiaCinque-durlindana a vir:IC9_Representation ;
    rdf:type gc:G16_Object ;
    crm:K14_symbolize :durlindana-abbandono_destino_bellicoso ;
    crm:P190_has_symbolic_content "l'ozio della Durlindana rimasta appesa a un albero e dimenticata" .

:cinque-di-denari-storiaCinque-energie_e_beni a vir:IC9_Representation ;
    rdf:type gc:G5_Narrative_Event ;
    crm:K14_symbolize :energie_e_beni-spreco ;
    crm:P190_has_symbolic_content "spreco d'energie e di beni" .

:la-luna-storiaCinque-luna a vir:IC9_Representation ;
    rdf:type gc:G13_Narrative_Location ;
    crm:K14_symbolize :luna-sconfitta ;
    crm:P190_has_symbolic_content "una terra oramai lunare" .

:il-matto-storiaCinque-orlando a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :orlando-pazzia ;
    crm:P190_has_symbolic_content "Sfogato ormai il più grosso groppo di furore, [...] con la testa piena di penne [...] ecco che Orlando era disceso giù nel cuore caotico delle cose, [...] al punto d'intersezione di tutti gli ordini possibili." .

:tre-di-coppe-storiaCinque-ampolla a vir:IC9_Representation ;
    rdf:type gc:G16_Object ;
    crm:K14_symbolize :ampolla-custodia_della_ragione ;
    crm:P190_has_symbolic_content "La sua ragione? [...] un'ampolla custodita nella Valle delle Ragioni Perdute" .

:la-giustizia-storiaCinque-cavalieri a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :cavalieri-recupero_della_ragione ;
    crm:P190_has_symbolic_content "i cavalieri dell'Armata di Carlomagno seguivano le piste del loro campione [...], non rinunciavano a riportare la sua spada al servizio di Ragione e Giustizia." .

:il-penduto-storiaCinque-orlando a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :orlando-armonia ;
    crm:P190_has_symbolic_content "Il paladino legato a testa in giù [...] Lasciatemi così. Ho fatto tutto il giro e ho capito. Il mondo si legge all'incontrario. Tutto è chiaro." .

:cavaliere-di-bastoni-storiaSei-astolfo a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :astolfo-cavaliere ;
    crm:P190_has_symbolic_content "colui che del recupero s'era fatto un dovere [...] Astolfo" .

:asso-di-spade-storiaSei-durlindana a vir:IC9_Representation ;
    rdf:type gc:G16_Object ;
    crm:K14_symbolize :durlindana-assenza_di_orlando ;
    crm:P190_has_symbolic_content "la Durlindana d'Orlando rimasta inoperosa appesa a un albero..." .

:lo-imperatore-storiaSei-carlo_magno a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :carlo_magno-regalità ;
    crm:P190_has_symbolic_content "raffigurato con la barba bianca e la fiorita saggezza di Carlo Magno in trono..." .

:nove-di-coppe-storiaSei-banchetto a vir:IC9_Representation ;
    rdf:type gc:G5_Narrative_Event ;
    crm:K14_symbolize :banchetto-convivialità ;
    crm:P190_has_symbolic_content "Prolungandosi l'assenza d'Orlando dal Campo Franco, Astolfo fu chiamato da Re Carlo e invitato a sedere a banchetto con lui..." .

:il-matto-storiaSei-orlando a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :orlando-pazzia ;
    crm:P190_has_symbolic_content "[...] Orlando, nostro nipote, ha perso il lume che distingue l'uomo e le bestie savie dalle bestie e dagli uomini matti, e adesso corre [...] cosparso di penne d'uccelli [...]." .

:lo-amore-storiaSei-amore a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :amore-eros ;
    crm:P190_has_symbolic_content "[...] alla pazzia lo ha spinto Eros, dio pagano, che più è represso più devasta..." .

:il-mondo-storiaSei-parigi_assediata a vir:IC9_Representation ;
    rdf:type gc:G13_Narrative_Location ;
    crm:K14_symbolize :parigi_assediata-nemico_saraceno ;
    crm:P190_has_symbolic_content "Parigi nella cerchia dei suoi baluardi, stretta da mesi nell'assedio saraceno" .

:la-torre-storiaSei-caduta_dei_cadaveri a vir:IC9_Representation ;
    rdf:type gc:G5_Narrative_Event ;
    crm:K14_symbolize :caduta_dei_cadaveri-sconfitta ;
    crm:P190_has_symbolic_content "il precipitare dei cadaveri giù dagli spalti tra getti d'olio rovente e macchine d'assedio all'opera" .

:nove-di-spade-storiaSei-orlando a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :orlando-speranza ;
    crm:P190_has_symbolic_content "Solo nostro nipote potrebbe guidarci in una sortita che tagli il cerchio di ferro e di fuoco..." .

:lo-eremita-storiaSei-indovino a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :indovino-sapienza ;
    crm:P190_has_symbolic_content "un vecchio gobbo con la clessidra in mano, un indovino che rovescia il tempo irreversibile e prima del prima vede il dopo. [...] a questo sapiente o magomerlino che Astolfo si rivolge per ritrovare la ragione di Orlando" .

:il-giudizio-storiaSei-cielo a vir:IC9_Representation ;
    rdf:type gc:G16_Object ;
    crm:K14_symbolize :cielo-ascensione ;
    crm:P190_has_symbolic_content "È in cielo che tu devi salire Astolfo [...] indicava un'ascensione sovrumana" .

:dieci-di-coppe-storiaSei-deposito a vir:IC9_Representation ;
    rdf:type gc:G13_Narrative_Location ;
    crm:K14_symbolize :deposito-custodia_pensieri ;
    crm:P190_has_symbolic_content "uno sterminato deposito conserva dentro ampolle messe in fila [...] le storie che gli uomini non vivono, i pensieri [...]." .

:il-carro-storiaSei-ippogrifo a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :ippogrifo-movimento ;
    crm:P190_has_symbolic_content "Astolfo il suo Ippogrifo l'aveva e montò in sella. Prese il largo nel cielo." .

:la-luna-storiaSei-luna a vir:IC9_Representation ;
    rdf:type gc:G13_Narrative_Location ;
    crm:K14_symbolize :luna-meta ;
    crm:P190_has_symbolic_content "La Luna crescente gli venne incontro." .

:la-ruota-della-fortuna-storiaSei-luna a vir:IC9_Representation ;
    rdf:type gc:G13_Narrative_Location ;
    crm:K14_symbolize :luna-mondo_allo_incontrario ;
    crm:P190_has_symbolic_content "una descrizione più particolareggiata del mondo della Luna, che ci lasciasse sbizzarrire nelle vecchie fantasie d'un mondo all'incontrario [...]." .

:il-bagatto-storiaSei-poeta a vir:IC9_Representation ;
    rdf:type gc:G1_Character ;
    crm:K14_symbolize :poeta-narratore ;
    crm:P190_has_symbolic_content "nome e immagine di significato controverso ma che qui pure può intendersi - dal calamo che tiene in mano come se scrivesse - un poeta." .

:asso-di-denari-storiaSei-luna a vir:IC9_Representation ;
    rdf:type gc:G13_Narrative_Location ;
    crm:K14_symbolize :luna-deserto ;
    crm:P190_has_symbolic_content "la Luna è un deserto, [...] da questa sfera arida parte ogni discorso e ogni poema [...]." .


