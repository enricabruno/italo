    lrmoo:R4_embodies :presentazione ;
    rdam:P30156 "Presentazione" .

:capitoloUno a lrmoo:F3_Manifestation ;
    lrmoo:R4_embodies :storiaUno ;
    rdam:P30156 "Storia dell'ingrato punito" .

:capitoloDue a lrmoo:F3_Manifestation ;
    lrmoo:R4_embodies :storiaDue ;
    rdam:P30156 "Storia dell'alchimista che vendette l'anima" .

:capitoloTre a lrmoo:F3_Manifestation ;
    lrmoo:R4_embodies :storiaTre ;
    rdam:P30156 "Storia della sposa dannata" .

:capitoloQuattro a lrmoo:F3_Manifestation ;
    lrmoo:R4_embodies :storiaQuattro ;
    rdam:P30156 "Storia d'un ladro di sepolcri" .

:capitoloCinque a lrmoo:F3_Manifestation ;
    lrmoo:R4_embodies :storiaCinque ;
    rdam:P30156 "Storia dell'Orlando pazzo per amore" .

:capitoloSei a lrmoo:F3_Manifestation ;
    lrmoo:R4_embodies :storiaSei ;
    rdam:P30156 "Storia di Astolfo sulla Luna" .

:capitoloSette a lrmoo:F3_Manifestation ;
    lrmoo:R4_embodies :tutteLeAltreStorie ;
    rdam:P30156 "Tutte le altre storie" .


# ----- Tabella 7: desmos:SemanticConstraint -----

:lipophony_cons a desmos:SemanticConstraint ;
    rdfs:label "Lipofonia" ;
    skos:definition "Vincolo semantico legato ai personaggi ai quali manca la voce. Il termine è stato mutuato da Marcel Benabou (lipophonie)." ;
    skos:related <https://www.wikidata.org/wiki/Q836165> ;
    desmos:hasVisibility :visible_explicity ;
    desmos:hasDegreeOfComplexity :soft ;
    desmos:involvesOperation :soustraction .

:mazzo-il-castello-dei-destini-incrociati a desmos:SemanticConstraint ;
    rdfs:label "Mazzo di carte" ;
    skos:definition "Vincolo semantico legato al tema delle storie che sono costruite creando delle sequenze narrative con un mazzo di tarocchi cinquecentesco che rimanda ad una ambientazione cavalleresca." ;
    skos:exactMatch <https://www.wikidata.org/wiki/Q726633> ;
    desmos:hasVisibility :visible_explicity ;
    desmos:hasDegreeOfComplexity :soft ;
    desmos:involvesOperation :displacement .


# ----- Tabella 8: desmos:FormalConstraint -----

:magic-square_cons a desmos:FormalConstraint ;
    rdfs:label "Quadrato magico" ;
    skos:definition "Vincolo formale legato alla disposizione delle carte. Ogni sequenza di carte corrisponde ad una storia all'interno della collezione. Dal momento che ogni sequenza all'interno del quadrato può essere letto da sinistra a destra, da destra a sinistra, da sopra a sotto o da sotto a sopra alcune carte si ripetono in più di una storia." ;
    skos:exactMatch <https://www.wikidata.org/wiki/Q192089> ;
    desmos:hasVisibility :visible_explicity ;
    desmos:hasDegreeOfComplexity :hard ;
    desmos:involvesOperation :displacement .


